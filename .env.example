# ============================================================================
# CLAIM INTELLIGENCE — .env.example
# ============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o .env real — ele está no .gitignore.
# ============================================================================

# ----------------------------------------------------------------------------
# AZURE AI FOUNDRY
# ----------------------------------------------------------------------------
# Connection string do Foundry Project (encontre em: Foundry → Project → Settings)
AZURE_AI_PROJECT_CONNECTION_STRING=eastus2.api.azureml.ms;<subscription-id>;<rg>;<project-name>

# Nome do agent (criado via Foundry)
AZURE_AGENT_NAME=claim-processor

# ----------------------------------------------------------------------------
# AZURE OPENAI (deployments)
# ----------------------------------------------------------------------------
AZURE_OPENAI_DEPLOYMENT_GPT=gpt-4o-claim
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-ada-002

# ----------------------------------------------------------------------------
# AZURE AI VISION
# ----------------------------------------------------------------------------
AZURE_VISION_ENDPOINT=https://vision-claim-intelligence.cognitiveservices.azure.com/
AZURE_VISION_KEY=<sua-key-aqui>

# ----------------------------------------------------------------------------
# AZURE DOCUMENT INTELLIGENCE
# ----------------------------------------------------------------------------
AZURE_DOCINTEL_ENDPOINT=https://docintel-claim-intelligence.cognitiveservices.azure.com/
AZURE_DOCINTEL_KEY=<sua-key-aqui>

# ----------------------------------------------------------------------------
# AZURE AI SEARCH
# ----------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://search-claim-intelligence.search.windows.net
AZURE_SEARCH_KEY=<sua-key-aqui>
AZURE_SEARCH_INDEX=policies-knowledge-base

# ----------------------------------------------------------------------------
# AZURE BLOB STORAGE
# ----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT_NAME=stclaimintelligence
AZURE_STORAGE_CONNECTION_STRING=<sua-connection-string-aqui>
AZURE_STORAGE_CONTAINER_IMAGES=damage-images
AZURE_STORAGE_CONTAINER_DOCUMENTS=documents

# ----------------------------------------------------------------------------
# APPLICATION INSIGHTS (opcional — para observability custom)
# ----------------------------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=<sua-connection-string-aqui>

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------------------
ENVIRONMENT=development
